# Microsoft Word lock / owner files (never commit)
~$*
**/~$*

# Local editor (optional machine-specific)
.vscode/

# OS
.DS_Store
Thumbs.db

# Local virtualenvs
.venv/
.venv-ci/

# Python cache artifacts
__pycache__/
*.egg-info/
*.py[cod]
.pytest_cache/
tests/__pycache__root_old/


# Local Cursor state; shared agent rules under .cursor/rules/ are tracked.
.cursor/*
!.cursor/rules/
!.cursor/rules/**
.cursor/debug-*.log

# Local file testing (compare CLI / desktop output; entire directory untracked)
tested_output/

# Golden baseline refresh script output (.docx per pair)
golden-corpus-output/

# Ad-hoc golden harness / refresh temp dirs (local only; not committed baselines)
golden-corpus-out-*/
golden-corpus-output-tmp*/
golden-refresh-ib-tmp/

# Local scratch / temp output
tmp/
tmp-*/

# Ad-hoc compare outputs from local desktop/CLI runs (not part of the corpus)
# e.g. compare_v5.docx, compare_v7.docx, compare_out.docx, … under sample-docs
sample-docs/**/compare_*.docx
parse_xml.py

# Local-only files not to push
AGENTS.md
.prettierrc


.coverage

.pytest_full_run.log
.pytest_full_run2.log
coverage.xml